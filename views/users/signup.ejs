<% layout("/layouts/boilerplate") %>


<div class="row mt-3">
    <h1 class="col-6 offset-3">Signup on Wanderlust</h1>
    <div class="col-6 offset-3 mb-3">
        <form action="/signup" method="post" class="needs-validation" novalidate>
            <div class="mb-3">
                <label for="username" id="username" class="form-label">Username</label>
                <input name="username" class="form-control" type="text" required>
                <div class="valid-feedback">Looks good!</div>
            </div>
             <div class="mb-3">
                <label for="email" id="email" class="form-label">Email</label>
                <input name="email" class="form-control" type="email" required>
            </div>
             <div class="mb-3">
                <label for="password" id="password" class="form-label">Password</label>
                <input name="password" class="form-control" type="password" required>
            </div>
            <div class="mb-3">
                <label class="form-label">Signup As</label><br>
                <input type="radio" name="role" value="user" checked> User  
                <input type="radio" name="role" value="host"> Host
            </div>
            <button class="btn btn-success">SignUp</button>
        </form>
    </div>
</div>